{
  "name": "@tosbas/form-zen",
  "version": "1.1.0",
  "description": "Lightweight TypeScript library for generating forms",
  "type": "module",

  "license": "MIT",
  "author": "Tosbas",

  "homepage": "https://github.com/tosbas/form-zen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tosbas/form-zen.git"
  },
  "bugs": {
    "url": "https://github.com/tosbas/form-zen/issues"
  },

  "publishConfig": {
    "access": "public"
  },

  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cdn": "./dist/cdn.global.js"
  },

  "browser": "./dist/cdn.global.js",
  "unpkg": "./dist/cdn.global.js",
  "jsdelivr": "./dist/cdn.global.js",

  "files": [
    "dist",
    "README.md"
  ],

  "sideEffects": false,

  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test test/index.test.js"
  },

  "keywords": [
    "form",
    "forms",
    "typescript",
    "frontend",
    "validation",
    "vanilla-js",
    "ui"
  ],

  "devDependencies": {
    "@types/node": "^25.9.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}